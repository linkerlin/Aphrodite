{
    "name": "aphrodite/framework",
    "description": "Aphrodite: AI-native PHP framework - Intent-driven development engine",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aphrodite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aphrodite\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable"
}
